<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <!--    <style name="Base.Theme.HANDIMAIN" parent="Theme.Material3.DayNight.NoActionBar">-->
    <style name="Base.Theme.HiHloApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/theme</item>
        <item name="colorPrimaryVariant">@color/theme</item>
        <item name="colorOnPrimary">@color/theme</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowDisablePreview">true</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <!-- Customize your theme here. -->
        <item name="cursorColor">@color/black</item>
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:forceDarkAllowed" tools:targetApi="q"> false</item>
        <item name="android:windowSplashScreenBackground" tools:ignore="NewApi">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:ignore="NewApi">0</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:ignore="NewApi">@null</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:ignore="NewApi">@android:color/transparent</item>
    </style>

<!--    <style name="Theme.HiHloApp" parent="Base.Theme.HiHloApp" />-->

    <style name="MyTabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabPaddingStart">8dp</item>
        <item name="tabPaddingEnd">8dp</item>
    </style>
    <style name="MyButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.App.CircularImageView" parent="">
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">150dp</item>
        <item name="android:scaleType">centerCrop</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.App.CornerSize50Percent</item>
        <item name="android:padding">2dp</item> <item name="strokeWidth">4dp</item>
        <item name="strokeColor">@color/theme</item> </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/RoundedBottomSheetShape</item>
    </style>

    <style name="RoundedBottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
    </style>

    <style name="ThemeDatePickerDialogTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/theme</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:background">@color/white</item>
    </style>
    <style name="UCropCustomTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Prevents overlap with status and nav bars -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item> <!-- or any color -->
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:navigationIcon">@color/black</item>
    </style>

    <style name="IOSBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/IOSBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="IOSBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="CustomBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <!-- Make bottom sheet background transparent -->
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>

        <!-- Force nav bar black -->
        <item name="android:navigationBarColor">@android:color/black</item>

        <!-- Prevent Android from dimming nav buttons -->
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>


</resources>