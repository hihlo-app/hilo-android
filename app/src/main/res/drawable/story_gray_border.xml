<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gray border -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/seekbar_running" /> <!-- light gray border -->
        </shape>
    </item>

    <!-- Inner circle -->
    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/screen_background_black" /> <!-- replace with your desired inner color -->
        </shape>
    </item>

</layer-list>
