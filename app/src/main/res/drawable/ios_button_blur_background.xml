<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#85000000" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Blur simulation with noise -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#30FFFFFF"
                android:centerColor="#15FFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="45" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Glass highlight -->
    <item android:top="1dp" android:bottom="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#25FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>