<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- Remote User Video (Full Screen) -->
        <FrameLayout
            android:id="@+id/localUser"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"

            android:layout_height="match_parent"
            android:background="#000000"
            android:visibility="visible"/>

        <!-- Local User Video (Small Floating Window) -->
        <!-- Remote User Video (Small Floating Window) -->
        <FrameLayout
            android:id="@+id/remoteUser"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:elevation="5dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="150dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <androidx.cardview.widget.CardView
            android:visibility="gone"
            android:id="@+id/minimiseIconCardView"
            android:backgroundTint="@color/gray_303030"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/personName"
            app:cardCornerRadius="30dp"
            android:layout_width="40dp"
            android:layout_height="40dp">
            <ImageView
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:id="@+id/minimiseIcon"
                android:layout_width="41dp"
                android:layout_height="41dp"
                android:src="@drawable/minimise"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_marginTop="40dp"
            android:gravity="center_horizontal"
            android:layout_marginHorizontal="50dp"
            android:maxLines="2"
            android:id="@+id/personName"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:fontFamily="@font/manrope_medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <Chronometer
            app:layout_constraintTop_toBottomOf="@id/personName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:id="@+id/callTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="50dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center_horizontal"
            android:text="Ringing..."
            android:textColor="@color/white_DADADA"
            android:textSize="13sp"/>
        <TextView
            android:gravity="center_horizontal"
            android:layout_marginHorizontal="20dp"
            android:id="@+id/tvUserName"
            android:textSize="20sp"
            android:visibility="gone"
            android:textColor="@color/white"
            android:fontFamily="@font/manrope_medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/personName"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.card.MaterialCardView
                android:visibility="gone"
                android:id="@+id/userImageCardView"
                app:strokeColor="@color/theme"
                app:cardCornerRadius="100dp"
                android:layout_width="150dp"
                android:layout_height="150dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/userImage"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvCityCountry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center_horizontal"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="visible"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/userImageCardView" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:paddingTop="20dp"
            android:paddingBottom="40dp"
            android:id="@+id/layoutBottom"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintEnd_toStartOf="parent"
            android:layout_width="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:background="@drawable/background_25dp_corner_no_stroke"
                android:backgroundTint="@color/white_20"
                android:paddingVertical="11dp"
                android:paddingHorizontal="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:visibility="gone"
                    android:id="@+id/videoIconCardview"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="30dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginHorizontal="10dp">
                <ImageView
                    android:id="@+id/videoIcon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/video_button_icon"
                    android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_marginHorizontal="10dp"
                    android:id="@+id/speakerCardview"
                    android:visibility="gone"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="30dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp">
                    <ImageView
                        android:id="@+id/speaker"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/speaker_off"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:backgroundTint="@color/white_30"
                    android:layout_marginHorizontal="10dp"
                    android:id="@+id/muteCardview"
                    android:visibility="gone"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="30dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp">
                    <ImageView
                        android:id="@+id/mute"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/mute_icon_with_round_border"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>

                <!-- End Call Button -->


                <ImageView
                    android:visibility="gone"
                    android:id="@+id/switchCamera"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/switch_camera"
                    android:scaleType="centerCrop"
                    android:layout_marginHorizontal="10dp" />
                <ImageView
                    android:id="@+id/idJoinId"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:text="Join"
                    android:src="@drawable/pick_call"
                    android:textSize="30sp"
                    android:textColor="@color/white"
                    android:scaleType="centerCrop"
                    android:layout_marginHorizontal="10dp"/>
                <ImageView
                    android:id="@+id/leaveBtn"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/end_call"
                    android:scaleType="centerCrop"
                    android:layout_marginHorizontal="10dp" />
            </LinearLayout>
        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
