        android:weightSum="1"
        android:orientation="vertical">-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_background_black"
        android:orientation="vertical"
        android:weightSum="1"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:descendantFocusability="afterDescendants">
        <TextView
            android:id="@+id/tvCreateAccount"
            android:paddingTop="50dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create an account"
            android:textSize="24sp"

            android:gravity="center"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="@font/manrope_semibold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="parent"/>

        <TextView
            android:paddingHorizontal="15dp"
            android:id="@+id/tvCreateDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect with your friends today!"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="5dp"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="@font/manrope_regular"
            app:layout_constraintTop_toBottomOf="@id/tvCreateAccount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="parent"/>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_weight="1"
            android:id="@+id/scrollView"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:clipChildren="false">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Your Name"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray_hint"
                    android:padding="15dp"
                    android:layout_marginTop="25dp"
                    android:inputType="textPersonName"
                    app:layout_constraintTop_toTopOf="parent"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030"/>

                <EditText
                    android:id="@+id/etUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Your Username"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textColorHint="#BFBBBB"
                    android:paddingVertical="15dp"
                    android:paddingStart="15dp"
                    android:paddingEnd="50dp"
                    android:imeOptions="actionNext"
                    android:layout_marginTop="20dp"
                    android:inputType="textPersonName"
                    app:layout_constraintTop_toBottomOf="@id/etName"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030"/>
                <ImageView
                    android:visibility="visible"
                    android:id="@+id/username_check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintTop_toTopOf="@+id/etUserName"
                    app:layout_constraintBottom_toBottomOf="@+id/etUserName"
                    app:layout_constraintEnd_toEndOf="@+id/etUserName"/>
                <TextView
                    android:text=""
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/etUserName"
                    app:layout_constraintEnd_toEndOf="@id/etUserName"
                    android:id="@+id/usernameWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/theme"
                    android:fontFamily="@font/manrope_medium"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Your Email"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textColorHint="#BFBBBB"
                    android:padding="15dp"
                    android:layout_marginTop="20dp"
                    android:inputType="textEmailAddress"
                    app:layout_constraintTop_toBottomOf="@id/usernameWarning"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030"/>


                <EditText
                    android:id="@+id/etPhoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Your Phone Number"
                    android:maxLines="1"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:maxLength="10"
                    android:textColor="@color/white"
                    android:textColorHint="#BFBBBB"
                    android:padding="15dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/etEmail"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/etPhoneNumber"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030">
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/enter_your_password"
                        android:background="@null"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textColorHint="#BFBBBB"
                        android:padding="15dp"
                        android:inputType="textPassword"
                        app:layout_constraintEnd_toStartOf="@id/password_toggle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <ImageView
                        android:id="@+id/password_toggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="10dp"
                        app:tint="@color/white"
                        android:src="@drawable/close_eye_2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clCnfPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clPassword"
                    android:background="@drawable/background_10dp_corner_round"
                    android:backgroundTint="@color/black_303030">
                    <EditText
                        android:id="@+id/etCnfPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/re_enter_your_password"
                        android:background="@null"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textColorHint="#BFBBBB"
                        android:padding="15dp"
                        android:inputType="textPassword"
                        app:layout_constraintEnd_toStartOf="@id/cnfPassword_toggle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <ImageView
                        android:id="@+id/cnfPassword_toggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/close_eye_2"
                        app:tint="@color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignUp"
                    style="@style/MyButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="104dp"
                    android:paddingVertical="18dp"
                    android:text="Sign Up"
                    app:layout_constraintTop_toBottomOf="@id/clCnfPassword"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvOrWith"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/white"
                    android:text="@string/or_with"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/manrope_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSignUp"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clGoogleLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp"
                    android:elevation="2dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/background_login_edittext"
                    app:layout_constraintTop_toBottomOf="@id/tvOrWith">

                    <ImageView
                        android:id="@+id/ivGoogle"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_google"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Sign up with Google"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:fontFamily="@font/manrope_semibold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivGoogle"
                        app:layout_constraintTop_toTopOf="@id/ivGoogle"
                        app:layout_constraintBottom_toBottomOf="@id/ivGoogle"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tvDontHaveAccount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/white"
                    android:text="Don’t have an account ? Sign Up"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginTop="30dp"
                    android:layout_marginHorizontal="20dp"
                    android:fontFamily="@font/manrope_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clGoogleLogin"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    app:layout_constraintTop_toBottomOf="@id/tvDontHaveAccount"/>




            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>

    </LinearLayout>
    <!--
        </ScrollView>
    -->
</layout>