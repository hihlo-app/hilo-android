<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:fontFamily="@font/manrope_semibold"
            android:textColor="@color/white_40"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/date"
            android:text="10-11-2024"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/outerLayout"
            android:layout_below="@id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="5dp"
            android:layout_marginHorizontal="10dp"
            >
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/innerLayout"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:paddingEnd="15dp"
                android:layout_height="wrap_content"
                android:background="@drawable/background_10dp_corner_round"
                android:backgroundTint="@color/gray_303030">
                <ImageView
                    android:layout_margin="10dp"
                    android:id="@+id/coin_image"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/gift_with_coin_icon"
                    android:fontFamily="@font/manrope_regular"
                    android:text="I am doing well, Can we meet tomorrow?"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_marginStart="10dp"
                    android:id="@+id/numberOfCoins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coins"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="15sp"                    android:visibility="visible"
                    app:layout_constraintTop_toTopOf="@id/coin_image"
                    app:layout_constraintBottom_toBottomOf="@id/coin_image"

                    app:layout_constraintStart_toEndOf="@id/coin_image"/>
                <TextView
                    android:layout_marginLeft="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/coin_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today, 8.36pm"
                    android:textSize="9sp"
                    android:id="@+id/timeView"
                    android:fontFamily="@font/manrope_light"
                    android:textColor="@color/white_DADADA"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:visibility="gone"
                android:id="@+id/reaction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/innerLayout"
                android:text="🥰"
                android:layout_marginTop="-7dp"
                android:layout_marginStart="10dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</layout>

