<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="23dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:id="@+id/myStoryGradient"

            android:layout_centerInParent="true"
            android:background="@drawable/story_gradient_border"
            android:gravity="center"
            />
        <androidx.cardview.widget.CardView
            android:id="@+id/userImageCardView"
            app:cardElevation="0dp"
            android:layout_margin="2dp"
            app:cardCornerRadius="30dp"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="@id/myStoryGradient"
            app:layout_constraintBottom_toBottomOf="@id/myStoryGradient"
            app:layout_constraintEnd_toEndOf="@id/myStoryGradient"
            app:layout_constraintStart_toStartOf="@id/myStoryGradient">

            <ImageView
                android:id="@+id/userImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>
        <ImageView
            app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
            app:layout_constraintEnd_toEndOf="@id/userImageCardView"
            android:id="@+id/onlineStatusImage"
            android:src="@drawable/online_status_green"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:layout_width="10dp"
            android:layout_height="10dp"/>

        <TextView
            android:layout_marginTop="2dp"
            android:id="@+id/name"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingEnd="2dp"
            android:textSize="13sp"
            android:fontFamily="@font/manrope_regular"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/userId"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginStart="10dp" />
        <ImageView
            android:id="@+id/verifiedNameTick"
            android:layout_marginStart="2dp"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:gravity="start"
            android:src="@drawable/verified_tick"
            app:layout_constraintTop_toTopOf="@id/name"

            app:layout_constraintBottom_toBottomOf="@+id/name"
            app:layout_constraintStart_toEndOf="@id/name"/>

        <TextView
            android:id="@+id/userId"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="10dp"
            android:textSize="13sp"
            android:fontFamily="@font/manrope_light"
            android:textColor="@color/white_DADADA"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/name"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            app:layout_constraintBottom_toTopOf="@id/userLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp" />

        <TextView
            android:id="@+id/userLocation"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="10dp"
            android:textSize="13sp"
            android:fontFamily="@font/manrope_light"
            android:textColor="@color/white_40"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userId"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
