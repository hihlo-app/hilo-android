<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/screen_background_black">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_marginTop="50dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingHorizontal="10dp"
                android:text="Notification Settings"
                android:fontFamily="@font/manrope_semibold"
                android:textColor="@color/white"
                android:textSize="22sp"/>
            <ImageView
                android:id="@+id/backButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:paddingVertical="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/back_button_pink"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clGeneralNotification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvGeneralNotification"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="General Notification"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchGeneral"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchGeneral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvGeneralNotification"
                        app:layout_constraintTop_toTopOf="@id/tvGeneralNotification"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clAudioCall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clGeneralNotification"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvAudioCall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Audio Call"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchAudioCall"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchAudioCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvAudioCall"
                        app:layout_constraintTop_toTopOf="@id/tvAudioCall"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clVideoCall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clAudioCall"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvVideoCall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Video Call"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchVideo"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchVideo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvVideoCall"
                        app:layout_constraintTop_toTopOf="@id/tvVideoCall"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:visibility="gone"
                    android:id="@+id/clPayments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clVideoCall"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvPayments"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Payments"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchPayments"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchPayments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvPayments"
                        app:layout_constraintTop_toTopOf="@id/tvPayments"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clFollowing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clPayments"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvFollowing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Following"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchFollowing"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchFollowing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvFollowing"
                        app:layout_constraintTop_toTopOf="@id/tvFollowing"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:visibility="gone"
                    android:id="@+id/clFollwers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/clFollowing"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    <TextView
                        android:id="@+id/tvFollowers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Followers"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/manrope_regular"
                        app:layout_constraintEnd_toStartOf="@id/switchFollowers"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchFollowers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:checked="true"
                        android:background="@null"
                        app:track="@drawable/custom_track_theme_colored"
                        android:thumb="@drawable/colored_thumb"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvFollowers"
                        app:layout_constraintTop_toTopOf="@id/tvFollowers"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

    </LinearLayout>


</layout>