<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/screen_background_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/storyImage"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="85dp"
            android:layout_marginTop="35dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>
        <SeekBar
            android:elevation="1dp"
            app:layout_constraintTop_toTopOf="@id/storyImage"
            android:layout_marginTop="10dp"
            android:id="@+id/storySeekBar"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:progress="0"
            android:max="100"
            android:thumb="@null"
            android:layout_marginHorizontal="-15dp"
            android:progressDrawable="@drawable/story_seekbar_progress_drawable" />

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="85dp"
            android:layout_marginTop="35dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:use_controller="true"
            app:controller_layout_id="@layout/story_exo_custom_controller"
            app:show_timeout="0"
            app:resize_mode="fit"
            app:surface_type="surface_view"
            android:focusable="false"
            android:clickable="false"/>

        <ProgressBar
            android:id="@+id/videoLoader"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomLayout"
            android:layout_marginTop="44dp"
            android:layout_gravity="center"
            android:visibility="gone" />
        <!--        <VideoView-->
        <!--            android:id="@+id/videoView"-->
        <!--            app:layout_constraintTop_toTopOf="parent"-->
        <!--            app:layout_constraintBottom_toTopOf="@id/bottomLayout"-->
        <!--            android:layout_marginTop="44dp"-->
        <!--            android:layout_width="match_parent"-->
        <!--            android:layout_height="0dp"/>-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/userDetailsLayout"
            android:layout_marginTop="60dp"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="15dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.cardview.widget.CardView
                android:backgroundTint="@color/black"
                android:id="@+id/userImageCardView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/userImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </androidx.cardview.widget.CardView>
            <ImageView
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintEnd_toEndOf="@id/userImageCardView"
                android:id="@+id/onlineStatusImage"
                android:src="@drawable/online_status_green"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/nameLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/userImageCardView">
                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="11dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="12sp"
                    android:textColor="@color/white"/>
                <ImageView
                    android:id="@+id/verifiedNameTick"
                    android:layout_marginStart="2dp"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/verified_tick"
                    app:layout_constraintStart_toEndOf="@+id/userName"
                    app:layout_constraintTop_toTopOf="@+id/userName"
                    app:layout_constraintBottom_toBottomOf="@id/userName"/>
                <TextView
                    android:id="@+id/statusTime"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="12sp"
                    android:textColor="@color/white_DADADA"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintStart_toEndOf="@+id/verifiedNameTick"
                    app:layout_constraintTop_toTopOf="@+id/userName"
                    app:layout_constraintBottom_toBottomOf="@id/userName"/>
                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:id="@+id/userLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="11dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/userName"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="12sp"
                    android:textColor="@color/white"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/sideOptions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="25dp"
                android:visibility="visible"
                android:layout_height="20dp"
                android:src="@drawable/side_options_vertical"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/leftClickArea"
            android:layout_width="80dp"
            android:layout_height="0dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/userDetailsLayout"
            app:layout_constraintBottom_toTopOf="@id/bottomLayout"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/rightClickArea"
            android:layout_width="80dp"
            android:layout_height="0dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/userDetailsLayout"
            app:layout_constraintBottom_toTopOf="@id/bottomLayout"
            app:layout_constraintEnd_toEndOf="parent" />
        <androidx.constraintlayout.widget.ConstraintLayout

            android:id="@+id/bottomLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">
            <LinearLayout
                android:id="@+id/seenLayout"
                android:layout_marginStart="15dp"
                android:layout_marginVertical="26dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/seen_views_eye"
                    android:layout_width="14dp"
                    android:layout_height="14dp"/>
                <TextView
                    android:id="@+id/seenCount"
                    android:layout_marginStart="5dp"
                    android:text="65"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/deleteButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="15dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:src="@drawable/delete_icon"/>
            <ImageView
                android:focusable="true"
                android:elevation="2dp"
                android:id="@+id/sendButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="@id/sendEditText"
                app:layout_constraintBottom_toBottomOf="@id/sendEditText"
                app:layout_constraintEnd_toEndOf="parent"
                android:src="@drawable/send_button_chat"/>
            <EditText
                android:maxLines="1"
                app:layout_constraintTop_toTopOf="parent"
                android:id="@+id/sendEditText"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="13dp"
                android:layout_marginBottom="3dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/background_25dp_corner_no_stroke"
                android:backgroundTint="@color/gray_303030"
                android:paddingHorizontal="13dp"
                android:paddingVertical="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/sendButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Message"
                android:fontFamily="@font/manrope_regular"
                android:textSize="14sp"
                android:textColorHint="@color/white"
                android:textColor="@color/white"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>