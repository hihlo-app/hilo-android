<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.cardview.widget.CardView
        android:layout_marginBottom="6dp"
        android:layout_marginHorizontal="3dp"
        android:layout_width="match_parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        android:shadowColor="@color/white"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:src="@drawable/sample_computer_image"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:id="@+id/backgroundImage"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:paddingHorizontal="7dp"
                android:layout_margin="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/background_15dp_corner_no_stroke">
                <ImageView
                    app:tint="@color/white"
                    android:visibility="gone"
                    android:id="@+id/interestImage"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/interest"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/interestImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:text="Fitness"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:paddingHorizontal="7dp"
                android:layout_marginVertical="6dp"
                android:layout_marginEnd="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="@drawable/background_15dp_corner_no_stroke">
                <ImageView
                    android:id="@+id/onlineStatusImage"

                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/online_status_green"/>
                <TextView
                    android:id="@+id/onlineText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:text="Online" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:maxWidth="160dp"
                android:id="@+id/userDetailsLayout"
                android:paddingEnd="10dp"
                android:layout_marginBottom="3dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/background_20dp_corner_no_stroke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <androidx.cardview.widget.CardView
                    android:id="@+id/userImageCardView"
                    android:layout_marginEnd="7dp"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:scaleType="centerCrop"
                        android:background="@color/black"
                        android:id="@+id/userImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </androidx.cardview.widget.CardView>
                <!--                <ImageView-->
                <!--                    app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"-->
                <!--                    app:layout_constraintEnd_toEndOf="@id/userImageCardView"-->
                <!--                    android:id="@+id/onlineStatusImage"-->
                <!--                    android:layout_marginEnd="2dp"-->
                <!--                    android:layout_marginBottom="2dp"-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="match_parent"/>-->
                <TextView
                    android:maxWidth="80dp"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/userLocation"
                    app:layout_constraintStart_toEndOf="@+id/userImageCardView"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:text="Isha_00dsadddddddddd"/>
                <ImageView
                    android:id="@+id/verifiedNameTick"
                    android:layout_marginStart="2dp"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/verified_tick"
                    app:layout_constraintTop_toTopOf="@id/userName"
                    app:layout_constraintStart_toEndOf="@+id/userName"
                    app:layout_constraintBottom_toBottomOf="@id/userName"/>
                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:id="@+id/userLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/userName"
                    app:layout_constraintStart_toEndOf="@+id/userImageCardView"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="6sp"
                    android:textColor="@color/white"
                    android:text="Jaipur, India"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>
</layout>


