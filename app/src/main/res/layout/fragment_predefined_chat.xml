<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.app.hihlo.ui.chat.view_model.ChatViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainLayout"
        android:fitsSystemWindows="true"
        android:background="@color/screen_background_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.chat.fragment.ChatFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="16dp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/backButton"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="15dp"
                android:layout_height="28dp"
                android:src="@drawable/back_button_pink_small"/>



            <TextView
                android:id="@+id/name"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginEnd="10dp"
                android:textSize="18sp"
                android:fontFamily="@font/manrope_semibold"
                android:textColor="@color/white"
                android:text="Fast Reply"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/horizontalLine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            android:background="#8D8D8D"/>

        <androidx.recyclerview.widget.RecyclerView
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toBottomOf="@+id/horizontalLine"
            app:layout_constraintBottom_toTopOf="@+id/bottomLayout"
            tools:listitem="@layout/adapter_predefined_chat"
            android:id="@+id/predefinedTextRecycler"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottomLayout"
            android:background="@drawable/background_25dp_corner_no_stroke"
            android:backgroundTint="@color/gray_303030"
            android:paddingStart="9dp"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/addButton">


            <EditText
                android:maxLines="3"
                android:id="@+id/chatEdittext"
                android:text="@={viewModel.message}"
                android:layout_marginStart="7dp"
                android:paddingTop="15dp"
                android:imeOptions="actionDone"
                android:paddingBottom="15dp"
                android:hint="Add a fast reply..."
                android:fontFamily="@font/manrope_light"
                android:textSize="13sp"
                android:textColorHint="@color/white"
                android:textColor="@color/white"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/viewMoreOption"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:visibility="gone"
                android:id="@+id/viewMoreOption"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="15dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/plus_icon_round" />


        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView

            android:text="Add"
            android:textColor="@color/theme"
            android:textSize="20sp"
            android:visibility="gone"
            android:id="@+id/addButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:src="@drawable/send_button"
            app:tint="@color/theme"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/bottomLayout"
            app:layout_constraintBottom_toBottomOf="@id/bottomLayout"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>