<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingTop="30dp"
        android:background="@color/screen_background_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.chat.fragment.ChatListFragment">

        <!-- Header Layout -->
        <LinearLayout
            android:visibility="gone"
            android:background="@color/theme"
            android:paddingHorizontal="15dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="20dp"
            android:id="@+id/callLayout"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/callerProfile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:scaleType="centerCrop"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/callerName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="4dp"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/callTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                />
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/callLayout">

            <ImageView
                android:visibility="gone"
                android:layout_width="15dp"
                android:layout_height="28dp"
                android:layout_marginStart="18dp"
                android:src="@drawable/back_button_pink"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:text="Messages"
                android:fontFamily="@font/manrope_semibold"
                android:textColor="@color/white"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Placeholder Text -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/searchLayout"
            android:background="@drawable/background_search_edittext"
            android:backgroundTint="@color/gray_303030"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:id="@+id/searchEdittext"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                android:fontFamily="@font/manrope_regular"
                android:hint="Search"
                android:textColorHint="@color/white"
                android:textCursorDrawable="@color/white"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@null"
                android:drawablePadding="8dp"
                android:drawableStart="@drawable/search_icon"/>
            <ImageView
                android:visibility="gone"
                android:id="@+id/crossButton"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/cross_button_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="17dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/switchTabLayout"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="@dimen/_3sdp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/searchLayout">

            <!-- Switch Container -->
            <FrameLayout
                android:id="@+id/switchContainer"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginHorizontal="15dp"
                android:backgroundTint="@color/gray_303030"
                android:background="@drawable/grey_outline_without_border"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Selector -->
                <View
                    android:id="@+id/viewSelector"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@drawable/background_10dp_corner_round_theme"
                     />

                <!-- Buttons -->
                <LinearLayout

                    android:id="@+id/layoutButtons"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:gravity="center"
                        android:id="@+id/inboxButton"
                        android:layout_width="145dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:text="Inbox"
                        android:letterSpacing="0"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:fontFamily="@font/manrope_semibold" />

                    <TextView

                        android:gravity="center"
                        android:id="@+id/requestButton"
                        android:layout_width="145dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:text="Request"
                        android:letterSpacing="0"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:fontFamily="@font/manrope_semibold" />
                </LinearLayout>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>



        <androidx.viewpager2.widget.ViewPager2
            app:layout_constraintTop_toBottomOf="@+id/switchTabLayout"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:id="@+id/viewPager"/>
