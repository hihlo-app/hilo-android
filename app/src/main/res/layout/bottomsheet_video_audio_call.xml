<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <LinearLayout
        android:id="@+id/bottomSheetLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/background_top_corners_round"
        android:backgroundTint="@color/white"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvBottomSheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Call"
            android:textColor="@color/theme"
            android:textSize="20sp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <!-- Two inner horizontal items -->
        <LinearLayout
            android:id="@+id/llOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Option 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvOption1Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Option 1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOption1Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subtitle 1" />
            </LinearLayout>

            <!-- Option 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvOption2Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio Call"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOption2Subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subtitle 2" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</layout>
