<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_marginTop="25dp"
        android:layout_marginHorizontal="23dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:backgroundTint="@color/black"
            app:cardElevation="0dp"
            android:id="@+id/notificationIconCardView"
            app:cardCornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="45dp"
            android:layout_height="45dp">
            <ImageView
                android:scaleType="centerCrop"
                android:id="@+id/notificationIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>
        <ImageView
            app:layout_constraintEnd_toEndOf="@id/notificationIconCardView"
            app:layout_constraintBottom_toBottomOf="@id/notificationIconCardView"
            android:id="@+id/notificationTypeIcon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/like_icon_reel"/>
        <TextView
            android:id="@+id/title"
            android:ellipsize="end"
            android:paddingEnd="2dp"
            android:textSize="13sp"
            android:fontFamily="@font/manrope_medium"
            android:textColor="@color/white"
            android:text="Notificaiton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/notificationIconCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp" />

        <TextView
            android:id="@+id/description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_regular"
            android:maxLines="1"
            android:paddingEnd="2dp"
            android:text="Notificaiton"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/notificationIconCardView"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintVertical_bias="1.0" />

        <TextView
            android:id="@+id/time"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="10dp"
            android:textSize="12sp"
            android:fontFamily="@font/manrope_medium"
            android:textColor="#6C6C6C"
            android:text="1m ago."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/description"
            app:layout_constraintStart_toEndOf="@id/notificationIconCardView"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
