<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <!-- If needed, add variables -->
    </data>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_marginHorizontal="10dp"
            android:backgroundTint="@color/white"
            app:cardCornerRadius="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/popupRoot"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="6dp"
                android:background="@color/gray_303030">

                <!-- Audio Call Option -->
                <LinearLayout
                    android:id="@+id/optionAudioCall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp">


                    <ImageView
                        android:layout_gravity="end"
                        android:id="@+id/ivAudioCall"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/call_icon_white"/>
                    <TextView
                        android:id="@+id/tvAudioCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Audio Call "
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_gravity="end"
                        android:id="@+id/audioCoinImage"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/coin_icon"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white"/>

                <!-- Video Call Option -->
                <LinearLayout
                    android:id="@+id/optionVideoCall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp">


                    <ImageView
                        android:layout_gravity="end"
                        android:padding="2dp"
                        android:id="@+id/ivVideoCall"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/video_call_icon_black"
                        app:tint="@android:color/white" />
                    <TextView
                        android:id="@+id/tvVideoCall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Video Call "
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_gravity="end"
                        android:id="@+id/videoCoinImage"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/coin_icon"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</layout>
