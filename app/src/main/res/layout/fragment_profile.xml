<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/screen_background_black"
        android:paddingTop="35dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="50dp"
                android:paddingTop="21dp"
                tools:context=".ui.profile.fragment.ProfileFragment">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/headerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:id="@+id/sideOptions"
                        android:src="@drawable/setting"
                        android:layout_marginEnd="19dp"
                        android:layout_width="23dp"
                        android:layout_height="20dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <LinearLayout
                        android:padding="3dp"
                        android:layout_marginEnd="15dp"
                        android:background="@drawable/background_round_corners"
                        android:backgroundTint="@color/black_303030"
                        android:id="@+id/walletButton"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/sideOptions"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:src="@drawable/coin_icon"
                            android:layout_marginEnd="5dp"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:scaleType="centerCrop"/>
                        <ImageView
                            android:src="@drawable/profile_add_media_icon"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:scaleType="centerCrop"/>
                    </LinearLayout>
                    <ImageView
                        android:visibility="gone"
                        android:id="@+id/backButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/back_button_pink"
                        android:paddingStart="20dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <LinearLayout
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="5dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/backButton"
                        app:layout_constraintEnd_toStartOf="@id/walletButton">
                        <TextView

                            android:id="@+id/name"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toEndOf="@id/backButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="19sp"/>
                        <ImageView
                            android:layout_marginStart="-17dp"
                            android:layout_gravity="center_vertical"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/verified_tick"
                            app:layout_constraintStart_toEndOf="@id/name"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:id="@+id/verifiedNameTick"/>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/profileDetailsLayout"
                    app:layout_constraintTop_toBottomOf="@+id/headerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profileCardView"
                        android:layout_marginTop="21dp"
                        android:layout_marginStart="15dp"
                        app:cardCornerRadius="100dp"
                        app:strokeWidth="0dp"
                        app:strokeColor="@color/theme"
                        android:layout_width="98dp"
                        android:layout_height="98dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <View
                            android:id="@+id/myStoryGradient"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:gravity="center"
                            app:layout_constraintBottom_toTopOf="@id/name"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                        <ImageView
                            android:id="@+id/profileImage"
                            android:scaleType="centerCrop"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                    </com.google.android.material.card.MaterialCardView>
                    <ImageView
                        android:elevation="1dp"
                        app:layout_constraintBottom_toBottomOf="@+id/profileCardView"
                        app:layout_constraintEnd_toEndOf="@id/profileCardView"
                        android:id="@+id/onlineStatusImage"
                        android:src="@drawable/online_status_green"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        android:layout_width="15dp"
                        android:layout_height="15dp"/>
                    <TextView
                        android:id="@+id/username"
                        android:layout_marginTop="5sp"
                        android:layout_marginStart="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white_FEFEFF"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/profileCardView"/>


                    <!--            <ImageView-->
                    <!--                android:visibility="gone"-->
                    <!--                android:id="@+id/editProfileButton"-->
                    <!--                android:elevation="2dp"-->
                    <!--                android:layout_width="28dp"-->
                    <!--                android:layout_height="28dp"-->
                    <!--                android:src="@drawable/edit_profile"-->
                    <!--                app:layout_constraintBottom_toBottomOf="@+id/profileCardView"-->
                    <!--                app:layout_constraintEnd_toEndOf="@id/profileCardView"/>-->
                    <androidx.recyclerview.widget.RecyclerView
                        android:nestedScrollingEnabled="false"
                        android:layout_marginStart="17dp"
                        android:layout_marginEnd="20dp"
                        tools:itemCount="4"
                        tools:listitem="@layout/adapter_show_profile_details"
                        android:id="@+id/profileDetailsRecycler"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="@id/profileCardView"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/profileCardView"/>
                    <TextView
                        android:id="@+id/bioTextview"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bio :"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_semibold"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/username"/>
                    <TextView
                        android:id="@+id/bioEditText"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="20dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/bioTextview"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/username"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:visibility="visible"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:id="@+id/followMessageLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/profileDetailsLayout">
                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guidelineHalfTwo"
                        android:orientation="vertical"
                        android:layout_width="1dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintGuide_percent="0.5"/>
                    <TextView
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guidelineHalfTwo"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/black_303030"
                        android:layout_marginEnd="8dp"
                        android:paddingVertical="9dp"
                        android:layout_weight="1"
                        android:id="@+id/followUserButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Follow"
                        android:gravity="center_horizontal"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"/>
                    <TextView
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/guidelineHalfTwo"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginStart="8dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/theme"
                        android:paddingVertical="9dp"
                        android:layout_weight="1"
                        android:id="@+id/messageUserButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Message"
                        android:gravity="center"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:id="@+id/editShareLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/profileDetailsLayout">
                    <TextView
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guidelineHalf"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/theme"
                        android:paddingVertical="9dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:id="@+id/editProfileButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Edit Profile"
                        android:gravity="center"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"/>
                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guidelineHalf"
                        android:orientation="vertical"
                        android:layout_width="1dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintGuide_percent="0.5"/>
                    <TextView
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/guidelineHalf"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/background_10dp_corner_round"
                        android:backgroundTint="@color/black_303030"
                        android:paddingVertical="9dp"
                        android:layout_weight="1"
                        android:id="@+id/shareButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Share"
                        android:gravity="center_horizontal"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/followersNumberLayout"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@+id/followMessageLayout"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/post"
                        android:textSize="16sp"
                        android:gravity="center_horizontal"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <TextView
                        android:id="@+id/followers"
                        android:gravity="center_horizontal"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <TextView
                        android:id="@+id/following"
                        android:gravity="center_horizontal"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/tabSelectorLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/followersNumberLayout">

                    <!-- Gallery Tab -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/gallery"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:src="@drawable/profile_gallery_icon"
                            android:layout_marginVertical="15dp" />

                        <!-- Indicator -->
                        <View
                            android:id="@+id/galleryIndicator"
                            android:layout_width="70dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/background_10dp_corner_round"
                            android:backgroundTint="@color/theme"
                            android:visibility="gone" /> <!-- default hidden -->
                    </LinearLayout>

                    <!-- Reels Tab -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/openReel"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/profile_reel_icon"
                            android:layout_marginVertical="15dp" />

                        <!-- Indicator -->
                        <View
                            android:id="@+id/reelIndicator"
                            android:layout_width="70dp"
                            android:layout_height="3dp"
                            android:background="@drawable/background_10dp_corner_round"
                            android:backgroundTint="@color/theme"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <androidx.viewpager2.widget.ViewPager2
                    android:layout_marginHorizontal="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tabSelectorLayout"

                    android:id="@+id/viewPager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>
        <ImageView
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="20dp"
            android:layout_marginEnd="20dp"
            android:padding="7dp"
            android:src="@drawable/profile_add_media_icon"
            android:id="@+id/addReel"
            android:text="9 \n Post"
            android:gravity="center_horizontal"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="@font/manrope_regular"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_weight="1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>