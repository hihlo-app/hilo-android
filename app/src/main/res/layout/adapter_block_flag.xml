<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/background_15dp_corner_no_stroke"
        android:layout_marginHorizontal="23dp"
        android:layout_marginTop="26dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#282828">

        <TextView
            android:id="@+id/reason"
            android:paddingVertical="15dp"
            android:paddingStart="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/selector"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_regular"
            android:textSize="17sp"
            android:text="Pretending to be someone"
            android:textColor="#BFBBBB" />

        <ImageView
            android:id="@+id/selector"
            android:layout_marginEnd="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/unselected_circle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>