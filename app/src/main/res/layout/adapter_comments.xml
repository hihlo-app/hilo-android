<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_marginStart="20dp"
        android:layout_marginTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/userImageCardView"
            app:cardElevation="0dp"
            app:cardCornerRadius="30dp"
            android:layout_width="35dp"
            android:layout_height="35dp"
            app:strokeColor="@color/theme"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:background="@color/transparent"
            android:backgroundTint="@color/transparent">

            <ImageView
                android:id="@+id/userImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/sample_profile"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/name"
            app:layout_constraintEnd_toEndOf="parent"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="20dp"
            android:textSize="12sp"
            android:fontFamily="@font/manrope_semibold"
            android:textColor="@color/white"
            android:text="Abhaysharma"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp" />

        <TextView
            android:id="@+id/userId"
            app:layout_constraintEnd_toEndOf="parent"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="20dp"
            android:textSize="11sp"
            android:fontFamily="@font/manrope_regular"
            android:textColor="@color/white_40"
            android:text="Abhay_06"
            app:layout_constraintTop_toBottomOf="@id/name"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp" />

        <TextView
            android:id="@+id/userLocation"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginEnd="20dp"
            android:textSize="10sp"
            android:fontFamily="@font/manrope_regular"
            android:textColor="@color/white_40"
            android:text="Abhaysharma"
            app:layout_constraintTop_toBottomOf="@id/userId"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp" />

        <TextView
            android:id="@+id/comment"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="20dp"
            android:textSize="12.5sp"
            android:fontFamily="@font/manrope_regular"
            android:textColor="@color/white"
            android:text="Nature at its best."
            app:layout_constraintTop_toBottomOf="@id/userLocation"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/action_lay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/comment"
            app:layout_constraintStart_toEndOf="@id/userImageCardView">

            <TextView
                android:id="@+id/reply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reply"
                android:textSize="12sp"
                android:textColor="@color/white_40"
                android:fontFamily="@font/manrope_regular"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingConstraints" />

            <TextView
                android:id="@+id/delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete"
                android:textSize="12sp"
                android:textColor="@color/white_40"
                android:fontFamily="@font/manrope_regular"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/reply"
                tools:ignore="MissingConstraints"
                android:visibility="gone"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/commentReplyRecycler"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/action_lay"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/userImageCardView"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="vertical"
            android:nestedScrollingEnabled="false"/>
