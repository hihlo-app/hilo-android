<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.app.hihlo.ui.chat.view_model.ChatViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainLayout"
        android:background="@color/screen_background_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="30dp"
        tools:context=".ui.chat.fragment.ChatFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/backButton"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="@id/userImageCardView"
                app:layout_constraintBottom_toBottomOf="@id/userImageCardView"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:src="@drawable/back_button_pink_small"/>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/userImageCardView"
                app:cardElevation="0dp"
                app:cardCornerRadius="30dp"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/backButton"
                android:background="@color/transparent"
                android:backgroundTint="@color/transparent">

                <ImageView
                    android:src="@drawable/sample_profile"
                    android:id="@+id/userImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
            <ImageView
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintEnd_toEndOf="@id/userImageCardView"
                android:id="@+id/onlineStatusImage"
                android:src="@drawable/online_status_green"
                android:layout_width="12dp"
                android:layout_height="12dp"/>


            <LinearLayout
                android:id="@+id/verifiedLayout"
                android:layout_marginEnd="10dp"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                app:layout_constraintEnd_toStartOf="@id/callIcon"
                app:layout_constraintTop_toTopOf="@id/userImageCardView"
                app:layout_constraintBottom_toTopOf="@id/userLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/name"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:layout_marginEnd="20dp"
                    android:textSize="15sp"
                    android:text="fadasdfasdfasdfsfafasdf"
                    android:fontFamily="@font/manrope_semibold"
                    android:textColor="@color/white"
                    app:layout_constraintTop_toTopOf="@id/userImageCardView"
                    app:layout_constraintBottom_toTopOf="@id/userLocation"
                    app:layout_constraintEnd_toStartOf="@+id/callIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="11dp" />
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/verifiedNameTick"
                    android:layout_marginStart="-17dp"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/verified_tick"
                    />
            </LinearLayout>

            <TextView
                android:visibility="gone"
                android:id="@+id/userId"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginEnd="10dp"
                android:textSize="12sp"
                android:fontFamily="@font/manrope_light"
                android:textColor="@color/white"
                android:text="Abhay_06"
                app:layout_constraintEnd_toStartOf="@+id/sideOptions"
                app:layout_constraintTop_toBottomOf="@id/verifiedLayout"
                app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp" />

            <TextView
                android:id="@+id/userLocation"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginEnd="10dp"
                android:textSize="11sp"
                android:lineSpacingExtra="0dp"
                android:fontFamily="@font/manrope_light"
                android:textColor="@color/white"
                app:layout_constraintEnd_toStartOf="@+id/callIcon"
                app:layout_constraintTop_toBottomOf="@id/verifiedLayout"
                app:layout_constraintBottom_toBottomOf="@id/userImageCardView"
                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp" />
            <ImageView
                android:id="@+id/callIcon"
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:src="@drawable/call_whatsapp_icon"
                app:tint="@color/white"
                app:layout_constraintEnd_toStartOf="@+id/sideOptions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView
                android:id="@+id/sideOptions"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_margin="-5dp"
                android:rotation="90"
                android:src="@drawable/side_option_black"
                app:tint="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:visibility="gone"
            android:id="@+id/horizontalLine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            android:background="#8D8D8D"/>
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toBottomOf="@+id/horizontalLine"
            app:layout_constraintBottom_toTopOf="@+id/waveLayout">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <LinearLayout
                    android:paddingBottom="10dp"
                    android:layout_marginTop="100dp"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="60dp">
                        <ImageView
                            android:src="@drawable/sample_profile"
                            android:id="@+id/userImageInner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_marginEnd="10dp"
                        android:layout_marginTop="5dp"
                        app:layout_constraintStart_toEndOf="@id/userImageCardView"
                        app:layout_constraintEnd_toStartOf="@id/callIcon"
                        app:layout_constraintTop_toTopOf="@id/userImageCardView"
                        app:layout_constraintBottom_toTopOf="@id/userLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/nameInner"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:layout_marginEnd="3dp"
                            android:textSize="18sp"
                            android:fontFamily="@font/manrope_semibold"
                            android:textColor="@color/white"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp" />
                        <ImageView
                            android:layout_gravity="center_vertical"
                            android:id="@+id/verifiedNameTickInner"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/verified_tick"
                            />
                    </LinearLayout>

                    <TextView
                        android:visibility="gone"
                        android:id="@+id/userIdInner"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:layout_marginEnd="10dp"
                        android:textSize="13sp"
                        android:fontFamily="@font/manrope_light"
                        android:textColor="@color/white"
                        android:text="Abhay_06"
                        app:layout_constraintEnd_toStartOf="@+id/sideOptions"
                        app:layout_constraintTop_toBottomOf="@id/name"
                        app:layout_constraintBottom_toBottomOf="@+id/userImageCardView"                app:layout_constraintStart_toEndOf="@id/userImageCardView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp" />

                    <TextView
                        android:id="@+id/userLocationInner"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:layout_marginEnd="10dp"
                        android:textSize="13sp"
                        android:fontFamily="@font/manrope_light"
                        android:textColor="@color/white"
                        app:layout_constraintEnd_toStartOf="@+id/sideOptions"
                        app:layout_constraintTop_toBottomOf="@id/name"
                        app:layout_constraintBottom_toBottomOf="@id/userImageCardView"
                        app:layout_constraintStart_toEndOf="@id/userImageCardView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="11dp" />
                    <LinearLayout
                        android:visibility="visible"
                        android:layout_marginTop="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:background="@drawable/background_10dp_corner_round"
                            android:backgroundTint="@color/black_303030"
                            android:layout_marginEnd="8dp"
                            android:paddingVertical="6dp"
                            android:paddingHorizontal="15dp"
                            android:layout_weight="1"
                            android:id="@+id/viewProfile"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:text="View Profile"
                            android:gravity="center_horizontal"
                            android:fontFamily="@font/manrope_regular"
                            android:textSize="16sp"/>
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/background_10dp_corner_round"
                            android:backgroundTint="@color/black_303030"
                            android:layout_marginEnd="8dp"
                            android:paddingVertical="6dp"
                            android:paddingEnd="15dp">
                            <ImageView
                                android:id="@+id/liveStatusImage"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="15dp"
                                android:src="@drawable/online_status_green"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"/>
                            <TextView
                                android:layout_marginStart="10dp"
                                app:layout_constraintStart_toEndOf="@id/liveStatusImage"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:layout_weight="1"
                                android:id="@+id/liveStatusText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:text="Online"
                                android:gravity="center_horizontal"
                                android:fontFamily="@font/manrope_regular"
                                android:textSize="16sp"/>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/coinDeductionTextLayout"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <ImageView
                            android:layout_marginEnd="-20dp"
                            android:id="@+id/idCoinToDeduct"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/coinDeductionText"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/coin_icon"/>
                        <TextView
                            android:gravity="center_horizontal"
                            android:layout_marginStart="30dp"
                            android:visibility="visible"
                            android:id="@+id/coinDeductionText"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:text="5 will be deducted for starting new chat"
                            android:fontFamily="@font/manrope_light"
                            android:textSize="16sp"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/chatRecycler"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:visibility="gone"
            android:layout_marginBottom="12dp"
            tools:listitem="@layout/adapter_predefined_message_horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomLayout"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:id="@+id/predefinedTextRecycler"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:visibility="gone"
        android:id="@+id/waveLayout"
        android:paddingStart="9dp"
        android:layout_marginBottom="5dp"
        android:layout_marginHorizontal="12dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sendButton">
        <TextView
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/waveImageview"
            app:layout_constraintBottom_toBottomOf="@id/waveImageview"
            android:id="@+id/audioTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="0:05"
            android:includeFontPadding="false"
            android:gravity="center_horizontal"
            android:fontFamily="@font/manrope_regular"
            android:textSize="16sp"/>
        <ImageView
            android:paddingStart="12dp"
            android:scaleType="fitXY"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/sendAudioButton"
            app:layout_constraintStart_toEndOf="@id/audioTime"
            android:id="@+id/waveImageview"
            android:layout_width="0dp"
            android:layout_height="45dp"/>
        <ImageView
            android:id="@+id/deleteAudio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/sendAudioButton"
            app:layout_constraintBottom_toBottomOf="@id/sendAudioButton"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/voice_delete"/>

        <ImageView
            app:tint="@color/white"
            android:visibility="visible"
            android:id="@+id/playPauseAudio"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginVertical="5dp"
            android:layout_marginTop="18dp"
            android:layout_marginStart="5dp"
            android:src="@drawable/ic_play_video"
            app:layout_constraintEnd_toEndOf="@id/sendAudioButton"
            app:layout_constraintStart_toStartOf="@id/sendAudioButton"
            app:layout_constraintTop_toTopOf="@id/waveImageview"
            app:layout_constraintBottom_toBottomOf="@id/waveImageview"
            />
        <ImageView
            android:visibility="visible"
            android:id="@+id/sendAudioButton"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/send_button_chat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/playPauseAudio"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:visibility="visible"
            android:id="@+id/bottomLayout"
            android:background="@drawable/background_25dp_corner_no_stroke"
            android:backgroundTint="@color/gray_303030"
            android:paddingStart="9dp"
            android:layout_marginBottom="10dp"
            android:layout_marginHorizontal="5dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/sendButton">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:visibility="gone"
                android:id="@+id/preLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="300dp"
                android:maxHeight="300dp"
                android:paddingTop="10dp"
                app:layout_constraintBottom_toTopOf="@id/chatEdittext"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:id="@+id/topPredefinedView"
                    android:layout_width="50dp"
                    android:layout_height="2dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@drawable/background_15dp_white_no_stroke"/>
                <TextView
                    android:id="@+id/preLayoutText"
                    android:gravity="start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="5dp"
                    android:text="Fast Reply"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="20sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    tools:listitem="@layout/adapter_predefined_chat"
                    tools:itemCount="2"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="35dp"
                    android:id="@+id/predefinedRecycler"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="visible"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintBottom_toTopOf="@id/predefinedHorizontalView"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/closePredefined"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/closePredefined"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="10dp"
                    android:src="@drawable/cross_button_white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <View
                    android:id="@+id/predefinedHorizontalView"
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@color/theme"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:visibility="gone"
                android:id="@+id/replyLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent">
                <View
                    android:layout_width="3dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="5dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@color/theme"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@color/theme"/>
                <TextView
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="15dp"
                    android:id="@+id/replyUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text=""
                    android:textColor="@color/theme"
                    android:textSize="12sp"
                    android:visibility="visible"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/closeReply"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:layout_marginStart="15dp"
                    android:layout_marginBottom="8dp"
                    android:ellipsize="end"
                    android:id="@+id/replyUserMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:maxLines="1"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/closeReply"
                    app:layout_constraintTop_toBottomOf="@id/replyUserName"/>
                <ImageView
                    android:id="@+id/closeReply"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="10dp"
                    android:src="@drawable/cross_button_white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                android:visibility="gone"
                android:id="@+id/emojiButton"
                android:src="@drawable/emoji_icon"
                app:cardElevation="0dp"
                app:cardCornerRadius="30dp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@color/transparent"
                android:backgroundTint="@color/transparent">

            </ImageView>

            <EditText
                android:maxLines="3"
                android:id="@+id/chatEdittext"
                android:text="@={viewModel.message}"
                android:layout_marginStart="6dp"
                android:paddingTop="13dp"
                android:paddingEnd="15dp"
                android:imeOptions="actionDone"
                android:paddingBottom="13dp"
                android:hint="Message"
                android:fontFamily="@font/manrope_medium"
                android:textSize="16sp"
                android:textColorHint="@color/white"
                android:textColor="@color/white"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@id/emojiButton"
                app:layout_constraintEnd_toStartOf="@+id/addPredefinedChat"
                app:layout_constraintTop_toBottomOf="@+id/replyLayout" />

            <ImageView
                android:visibility="gone"
                android:id="@+id/viewMoreOption"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="15dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/plus_icon_round" />
            <TextView
                android:visibility="gone"
                android:background="@drawable/background_theme_color_border"
                android:id="@+id/addPredefinedChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:layout_marginEnd="12dp"
                android:textColor="@color/theme"
                android:text="Add"
                android:textSize="16sp"
                android:fontFamily="@font/manrope_medium"
                android:src="@drawable/profile_gallery_icon"
                app:layout_constraintEnd_toStartOf="@+id/openGallery"
                app:layout_constraintTop_toTopOf="@id/chatEdittext"
                app:layout_constraintBottom_toBottomOf="@id/chatEdittext"/>
            <ImageView
                android:id="@+id/openGallery"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:padding="4dp"
                android:layout_marginEnd="10dp"
                app:tint="@color/white"
                android:src="@drawable/profile_gallery_icon"
                app:layout_constraintEnd_toStartOf="@+id/openPredefinedChatScreen"
                app:layout_constraintTop_toTopOf="@id/chatEdittext"
                app:layout_constraintBottom_toBottomOf="@id/chatEdittext"/>
            <ImageView
                android:src="@drawable/open_predefined_chat"
                android:visibility="visible"
                android:layout_gravity="end"
                android:layout_marginEnd="15dp"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:text="+"
                android:textSize="35sp"
                android:textColor="@color/white"
                app:layout_constraintEnd_toStartOf="@id/giftButton"
                app:layout_constraintTop_toTopOf="@id/chatEdittext"
                app:layout_constraintBottom_toBottomOf="@id/chatEdittext"
                android:id="@+id/openPredefinedChatScreen"/>
            <ImageView
                android:id="@+id/giftButton"
                android:layout_width="23dp"
                android:layout_height="22dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/giftbold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/chatEdittext"
                app:layout_constraintBottom_toBottomOf="@id/chatEdittext" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <ImageView
            android:visibility="gone"
            android:id="@+id/sendButton"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/send_button_chat"
            app:layout_constraintEnd_toStartOf="@id/recordAudioButton"
            app:layout_constraintBottom_toBottomOf="@id/bottomLayout"/>
        <ImageView
