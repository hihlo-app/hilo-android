<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/screen_background_black"
        tools:context=".ui.signup.fragment.EmailFragment">
        <LinearLayout
            android:id="@+id/llBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp">
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:src="@drawable/back_button_pink"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </LinearLayout>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp">

                <TextView
                    android:id="@+id/tvKindly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter Phone Number"
                    android:textColor="@color/white"
                    android:layout_marginTop="40dp"
                    android:textSize="24sp"
                    android:fontFamily="@font/manrope_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tvPhoneDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/please_enter_your_phone_number_for_verification"
                    android:textColor="@color/textDescColor"
                    android:layout_marginTop="15dp"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/tvKindly"
                    android:fontFamily="@font/manrope_semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>


                <TextView
                    android:id="@+id/tvPhoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your phone number"
                    android:layout_marginTop="30dp"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_semibold"
                    app:layout_constraintTop_toBottomOf="@id/tvPhoneDesc"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:id="@+id/enterNumberLayout"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/background_login_edittext"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tvPhoneNumber"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <TextView
                        android:id="@+id/etCountryCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColorHint="@color/light_white"
                        android:paddingVertical="13dp"
                        android:paddingHorizontal="8dp"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"
                        android:singleLine="true"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:text="+91"
                        android:textColor="@color/light_white"
                        app:layout_constraintTop_toTopOf="@id/etPhoneNumber"
                        app:layout_constraintBottom_toBottomOf="@id/etPhoneNumber"
                        app:layout_constraintStart_toStartOf="@id/etPhoneNumber"
                        app:layout_constraintEnd_toEndOf="@id/etPhoneNumber" />
                    <EditText
                        android:background="@null"
                        android:layout_weight="1"
                        android:id="@+id/etPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColorHint="@color/light_white"
                        android:paddingVertical="13dp"
                        android:hint="Enter Your Phone Number"

                        android:paddingHorizontal="8dp"
                        android:fontFamily="@font/manrope_regular"
                        android:textSize="16sp"
                        android:singleLine="true"
                        android:inputType="number"
                        android:maxLength="10"
                        android:textColor="@color/light_white"
                        />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    style="@style/MyButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:layout_marginBottom="104dp"
                    android:paddingVertical="18dp"
                    android:text="@string/submit"
                    app:layout_constraintTop_toBottomOf="@id/enterNumberLayout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>


    </LinearLayout>
</layout>