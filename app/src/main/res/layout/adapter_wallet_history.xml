<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/background_theme_20dp_no_stroke"
        android:backgroundTint="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/userDetailsLayout"
            android:layout_marginTop="5dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="13dp"

            android:paddingBottom="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:padding="2dp"
                android:id="@+id/userImageCardView"
                android:layout_width="57dp"
                android:layout_height="57dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp">

                <ImageView
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_placeholder"
                    android:id="@+id/userImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/nameLayout"
                android:layout_width="0dp"
                android:layout_marginEnd="10dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/transactionStatusLayout"
                app:layout_constraintStart_toEndOf="@+id/userImageCardView">

                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:id="@+id/name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:text="Label"
                    />

                <TextView
                    android:visibility="gone"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:id="@+id/userName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    app:layout_constraintTop_toBottomOf="@+id/name"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:text="Label"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <ImageView
                    android:visibility="gone"
                    android:id="@+id/verifiedNameTick"
                    android:layout_marginStart="2dp"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/verified_tick"
                    app:layout_constraintStart_toEndOf="@+id/name"
                    app:layout_constraintTop_toTopOf="@+id/name"
                    app:layout_constraintBottom_toBottomOf="@id/userName" />

                <TextView
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:id="@+id/time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/userName"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:text="Label" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:paddingEnd="10dp"
                android:id="@+id/transactionStatusLayout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView
                    android:id="@+id/transactionStatusIcon"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:id="@+id/noOfCoins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:textSize="13sp"
                    android:textColor="@color/theme"
                    app:layout_constraintTop_toBottomOf="@id/transactionStatusIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="10dp"/>
                <ImageView
                    android:id="@+id/minusPlusIcon"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    app:layout_constraintEnd_toStartOf="@id/noOfCoins"
                    app:layout_constraintTop_toTopOf="@id/noOfCoins"
                    app:layout_constraintBottom_toBottomOf="@id/noOfCoins"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>